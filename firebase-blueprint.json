{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile including role",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Medical specialist details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "string" },
        "fee": { "type": "number" },
        "about": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "specialty", "fee"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Booking record",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientEmail": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["doctorId", "patientId", "date", "time", "status"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Medical record for an appointment",
      "type": "object",
      "properties": {
        "appointmentId": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "diagnosis": { "type": "string" },
        "medicines": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dosage": { "type": "string" },
              "duration": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "notes": { "type": "string" },
        "testCharges": { "type": "number", "description": "Charges for medical tests" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "diagnosis"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Registered doctors"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "All appointments"
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Medical prescriptions"
    }
  }
}
